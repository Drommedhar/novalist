{
  "compilerOptions": {
    "target": "ES2018",
    "module": "commonjs",
    "lib": ["ES2018", "DOM"],
    "outDir": ".",
    "rootDir": ".",
    "sourceMap": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@storyline/*": ["./vendor/storyline/*"]
    }
  },
  "include": ["src/**/*.ts", "vendor/storyline/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts"]
}
